# ─────────────────────────────────────────────────────────────────────────────
# Two SEPARATE Supabase Postgres projects — one per module, no shared tables.
# Locally these default to the two docker-compose Postgres instances (see below),
# so you can run everything without Supabase. In production, paste the Supabase
# pooler connection strings here.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL_SYNC=postgres://postgres:postgres@localhost:5433/sync
DATABASE_URL_METRICS=postgres://postgres:postgres@localhost:5434/metrics

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Problem 1 source credentials (live adapters) ────────────────────────────
# Each adapter falls back to recorded fixtures if its key is absent, so the app
# still boots and the demo still runs. Provide real keys to go live per-source.

# HubSpot — Private App access token from a developer/test account (CRM scopes)
HUBSPOT_PRIVATE_APP_TOKEN=

# Stripe — TEST mode secret key (sk_test_...) and webhook signing secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google Calendar — OAuth2 (run `npm run get-google-token` to mint the refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── Source mode override (optional) ─────────────────────────────────────────
# auto (default) = live if key present else fixture. Force with: live | fixture
SOURCE_MODE=auto
